{
    "compilerOptions": {
        "baseUrl": ".",
        "paths": {
            "@/*": [
                "./src/*"
            ],
            "@config/*": [
                "./src/config/*"
            ],
            "@api/*": [
                "./src/api/*"
            ],
            "@context/*": [
                "./src/context/*"
            ],
            "@hooks/*": [
                "./src/hooks/*"
            ],
            "@layouts/*": [
                "./src/layouts/*"
            ],
            "@pages/*": [
                "./src/pages/*"
            ],
            "@components/*": [
                "./src/components/*"
            ],
            "@utils/*": [
                "./src/utils/*"
            ],
            "@styles/*": [
                "./src/styles/*"
            ],
            "@assets/*": [
                "./src/assets/*"
            ]
        }
    }
}